{
  "name": "mmm-dropboxpictures",
  "version": "3.1.1",
  "description": "MagicMirror module for showing images from Dropbox. (Successor of MMM-DropboxWallpaper)",
  "author": "eouia0819@gmail.com",
  "keywords": [
    "MagicMirror",
    "Dropbox",
    "Pictures",
    "Wallpaper",
    "Image"
  ],
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MMRIZE/MMM-DropboxPictures.git"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "auth": "node --env-file-if-exists=.env auth.js",
    "lint": "eslint && prettier . --check",
    "lint:fix": "eslint --fix && prettier . --write",
    "postinstall": "cp example.env .env",
    "release": "commit-and-tag-version --config ./changelog.config.js",
    "test": "node --run lint && node --run test:unit",
    "test:unit": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "exifr": "^7.1.3"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.6.0",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "open": "^11.0.0",
    "prettier": "^3.8.5"
  }
}
